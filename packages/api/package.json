{
  "name": "@agentic/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "db:generate": "drizzle-kit generate --config=src/database/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=src/database/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=src/database/drizzle.config.ts"
  },
  "dependencies": {
    "@agentic/shared": "*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/apollo": "^13.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/swagger": "^11.1.0",
    "@apollo/server": "^5.0.0",
    "graphql": "^16.10.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "bcryptjs": "^3.0.0",
    "drizzle-orm": "^0.45.0",
    "postgres": "^3.4.0",
    "neo4j-driver": "^6.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0",
    "minio": "^8.0.0",
    "class-validator": "^0.15.0",
    "class-transformer": "^0.5.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.0",
    "drizzle-kit": "^0.31.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^30.0.0",
    "typescript": "~5.9.0",
    "ts-node": "^10.0.0"
  }
